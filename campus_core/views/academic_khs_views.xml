<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_academic_khs_tree" model="ir.ui.view">
        <field name="name">academic.khs.tree</field>
        <field name="model">academic.khs</field>
        <field name="arch" type="xml">
            <tree string="Student KHS">
                <field name="name"/>
                <field name="student_id"/>
                <field name="academic_year_id"/>
                <field name="term_type"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_academic_khs_form" model="ir.ui.view">
        <field name="name">academic.khs.form</field>
        <field name="model">academic.khs</field>
        <field name="arch" type="xml">
            <form string="Student KHS">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="term_type"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Grades">
                            <field name="khs_line_ids">
                                <tree editable="bottom">
                                    <field name="subject_id" readonly="1" force_save="1"/>
                                    <field name="schedule_ids" widget="many2many_tags"/>
                                    <field name="score"/>
                                    <field name="grade"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_academic_khs" model="ir.actions.act_window">
        <field name="name">Student KHS</field>
        <field name="res_model">academic.khs</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
